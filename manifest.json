{
  "manifest_version": 3,
  "name": "WebMonitor Pro",
  "version": "1.0.0",
  "description": "监控网页指定区域数值变动，定时刷新触发QQ提醒+提示音",
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "src/background/service_worker.js"
  },
  "options_page": "src/options/options.html",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "notifications",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "128": "icon.png"
  }
}

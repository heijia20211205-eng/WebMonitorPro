{
  "manifest_version": 3,
  "name": "WebMonitor Pro",
  "version": "1.0.0",
  "description": "Web page value monitor - periodic refresh, QQ alert, sound alert",
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "src/background/service_worker.js"
  },
  "options_page": "src/options/options.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'unsafe-inline'; object-src 'self'"
  },
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "notifications",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "128": "icon.png"
  }
}